{
  "expo": {
    "name": "mobile",
    "slug": "road-sos",
    "version": "1.0.0",
    "extra": {
      "eas": {
        "projectId": "0695436e-5b17-4a01-b759-3521363ad571"
      }
    },
    "owner": "yug_125",
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow RoadSOS to use your location for SOS services."
        }
      ]
    ],
    "android": {
      "package": "com.yug_125.roadsos",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "RECORD_AUDIO",
        "CALL_PHONE"
      ]
    }
  }
}
